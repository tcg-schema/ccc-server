# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/cardforge

# GitHub OAuth App credentials
# Create one at https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# The callback URL registered on your GitHub OAuth App.
# During local dev this is typically http://localhost:8080/auth/github/callback
# (or wherever the frontend redirects after GitHub approves)
GITHUB_REDIRECT_URI=https://your-frontend.netlify.app/auth/callback

# How long session tokens stay valid (hours). Default: 24
SESSION_EXPIRY_HOURS=24

# Secret token for the /admin?token= stats page. Set to a long random string.
ADMIN_TOKEN=
