# CardForge proxy — stateless. No database required.
#
# The browser runs the GitHub Authorization-Code + PKCE flow itself and posts
# the code here to be swapped for a token. The client id is public (it lives in
# the SPA bundle); the secret stays on this server and is injected into the
# exchange (GitHub requires it even with PKCE).

# GitHub OAuth App credentials.
# Create one at https://github.com/settings/developers → New OAuth App, and set
# the Authorization callback URL to <frontend-origin>/auth/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# CORS: comma-separated list of allowed frontend origins, or "*" for local dev.
# e.g. https://card-creator.tcg-schema.org
ALLOWED_ORIGINS=*
